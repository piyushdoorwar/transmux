<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <Color x:Key="SystemAccentColor">#3A6E9B</Color>
    <Color x:Key="SystemAccentColorLight1">#4B8FBE</Color>
    <Color x:Key="SystemAccentColorLight2">#5A9FCE</Color>
    <Color x:Key="SystemAccentColorLight3">#7AB7DC</Color>
    <Color x:Key="SystemAccentColorDark1">#2F587D</Color>
    <Color x:Key="SystemAccentColorDark2">#24445F</Color>
    <Color x:Key="SystemAccentColorDark3">#193044</Color>

    <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{StaticResource SystemAccentColor}" />
    <SolidColorBrush x:Key="SystemAccentColorLight1Brush" Color="{StaticResource SystemAccentColorLight1}" />
    <SolidColorBrush x:Key="SystemAccentColorLight2Brush" Color="{StaticResource SystemAccentColorLight2}" />
    <SolidColorBrush x:Key="SystemAccentColorLight3Brush" Color="{StaticResource SystemAccentColorLight3}" />
    <SolidColorBrush x:Key="SystemAccentColorDark1Brush" Color="{StaticResource SystemAccentColorDark1}" />
    <SolidColorBrush x:Key="SystemAccentColorDark2Brush" Color="{StaticResource SystemAccentColorDark2}" />
    <SolidColorBrush x:Key="SystemAccentColorDark3Brush" Color="{StaticResource SystemAccentColorDark3}" />
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Cantarell, Ubuntu, Inter, Segoe UI, sans-serif" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="#3D3846" />
    <Setter Property="Foreground" Value="#F7F5F3" />
    <Setter Property="BorderBrush" Value="#5E5968" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Transitions">
      <Transitions />
    </Setter>
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#4D4658" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="#2D2834" />
  </Style>

  <Style Selector="Button.accent">
    <Setter Property="Background" Value="#3A6E9B" />
    <Setter Property="BorderBrush" Value="#4B8FBE" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="Button.accent:pointerover">
    <Setter Property="Background" Value="#4382AD" />
  </Style>

  <Style Selector="Button.accent:pressed">
    <Setter Property="Background" Value="#2F587D" />
  </Style>

  <Style Selector="Button.icon">
    <Setter Property="Width" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Height" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.icon:pointerover">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Slider">
    <Setter Property="Foreground" Value="#3A6E9B" />
    <Setter Property="Focusable" Value="False" />
  </Style>

  <Style Selector="PathIcon">
    <Setter Property="Foreground" Value="#F7F5F3" />
  </Style>

  <!-- Window chrome buttons (minimize / close) -->
  <Style Selector="Button.wchrome">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="#AAAAAA" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Width" Value="42" />
    <Setter Property="MinWidth" Value="42" />
    <Setter Property="Height" Value="38" />
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Focusable" Value="False" />
  </Style>

  <Style Selector="Button.wchrome:pointerover">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.wchrome:pressed">
    <Setter Property="Background" Value="#333333" />
  </Style>

  <Style Selector="Button.wchrome.close:pointerover">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.wchrome.close:pressed">
    <Setter Property="Background" Value="#A01E12" />
  </Style>

  <!-- Link-style text buttons (About dialog footer) -->
  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="#3A6E9B" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style Selector="Button.link:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#5A9FCE" />
  </Style>

  <!-- ProgressBar blue fill -->
  <Style Selector="ProgressBar /template/ Border#PART_Indicator">
    <Setter Property="Background" Value="#3A6E9B" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="#F7F5F3" />
  </Style>

  <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="#3A6E9B" />
  </Style>

  <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1D2C36" />
  </Style>

  <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#4382AD" />
  </Style>

  <!-- Segmented mode toggle (Fast / Full) -->
  <Style Selector="Button.seg">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="#555" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Padding" Value="12,5" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="Button.seg:pointerover">
    <Setter Property="Background" Value="#2A2A2A" />
    <Setter Property="Foreground" Value="#AAAAAA" />
  </Style>

  <Style Selector="Button.seg-on">
    <Setter Property="Background" Value="#1D2C36" />
    <Setter Property="Foreground" Value="#5AA8D8" />
    <Setter Property="BorderBrush" Value="#2A4150" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.seg-on:pointerover">
    <Setter Property="Background" Value="#243847" />
    <Setter Property="Foreground" Value="#5DA4D6" />
  </Style>
</Styles>
