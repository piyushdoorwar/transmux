<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Lumyn logo as a DrawingImage — reusable at any size via <Image>.
    Coordinate space: 256 × 256.
    Stroke paths use a green Pen; the play-triangle uses a softened light fill.
  -->
  <DrawingImage x:Key="Icon.LumynLogo">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <!-- Signal lines -->
        <GeometryDrawing Geometry="M22 71.5L135 19">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 103.5L234 5">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 135.5L234 37">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 167.5L234 69">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <!-- TV body -->
        <GeometryDrawing Geometry="M96 118V181H62L67 207H189L194 181H159V130">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" LineJoin="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <!-- TV stand legs -->
        <GeometryDrawing Geometry="M71 217L184 197">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="12" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M75 239L176 221">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="12" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <!-- Play triangle -->
        <GeometryDrawing
            Brush="#D8D4CF"
            Geometry="M112 150C112 147.7 114.5 146.3 116.5 147.5L142.5 163.2C145.5 165 145.5 170 142.5 171.8L116.5 187.5C114.5 188.7 112 187.3 112 185V150Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!--
    Compact mark for small sizes (top bar, taskbar) — no stand legs.
  -->
  <DrawingImage x:Key="Icon.LumynMark">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Geometry="M22 71.5L135 19">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 103.5L234 5">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 135.5L234 37">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 167.5L234 69">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M96 118V181H62L67 207H189L194 181H159V130">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" LineJoin="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing
            Brush="#D8D4CF"
            Geometry="M112 150C112 147.7 114.5 146.3 116.5 147.5L142.5 163.2C145.5 165 145.5 170 142.5 171.8L116.5 187.5C114.5 188.7 112 187.3 112 185V150Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

</ResourceDictionary>
