<Application
    x:Class="Transmux.App.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
        <ColorPaletteResources x:Key="Dark" Accent="#3A6E9B" />
        <ColorPaletteResources x:Key="Light" Accent="#3A6E9B" />
      </FluentTheme.Palettes>
    </FluentTheme>
    <StyleInclude Source="avares://Transmux/Assets/Styles/Lumyn.axaml" />
  </Application.Styles>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Transmux/Assets/Icons/LumynLogo.axaml" />
        <ResourceInclude Source="avares://Transmux/Assets/Icons/TransmuxIcons.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
