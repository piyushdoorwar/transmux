<Window
    x:Class="Transmux.App.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Transmux.App.ViewModels"
    Title="Transmux"
    Width="850"
    Height="700"
    MinWidth="625"
    MinHeight="538"
    SystemDecorations="BorderOnly"
    Background="#111111"
    ExtendClientAreaToDecorationsHint="True">

  <Grid RowDefinitions="38,*,32">

    <!-- ── Top bar ──────────────────────────────────────────────────────── -->
    <Border Grid.Row="0" Background="#141414">
      <Grid ColumnDefinitions="Auto,*,Auto">

        <!-- Logo + title -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0">
          <Image Width="20" Height="20"
                 Source="{StaticResource Icon.TransmuxMark}"
                 VerticalAlignment="Center" />
          <TextBlock Text="Transmux"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="#DEDAD5"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Drag region -->
        <Border Grid.Column="1"
                Name="DragRegion"
                Background="Transparent"
                PointerPressed="DragRegion_PointerPressed" />

        <!-- Window chrome -->
        <StackPanel Grid.Column="2" Orientation="Horizontal">
          <Button Classes="wchrome"
                  Command="{Binding ShowKeyboardShortcutsCommand}"
                  ToolTip.Tip="Keyboard shortcuts (?)">
            <TextBlock Text="⌨" FontSize="14" Foreground="#888" />
          </Button>
          <Button Classes="wchrome"
                  Command="{Binding ShowHistoryCommand}"
                  ToolTip.Tip="Conversion history">
            <TextBlock Text="⏱" FontSize="14" Foreground="#888" />
          </Button>
          <Button Classes="wchrome"
                  Command="{Binding OpenAboutDialogCommand}"
                  ToolTip.Tip="About">
            <PathIcon Width="14" Height="14"
                      Data="{StaticResource Icon.Info}"
                      Foreground="#888" />
          </Button>
          <Button Classes="wchrome"
                  Name="MinimizeButton"
                  Click="MinimizeButton_Click">
            <PathIcon Width="12" Height="12"
                      Data="{StaticResource Icon.Minimize}"
                      Foreground="#888" />
          </Button>
          <Button Classes="wchrome"
                  Name="MaximizeButton"
                  Click="MaximizeButton_Click">
            <PathIcon Name="MaximizeIcon"
                      Width="11" Height="11"
                      Data="{StaticResource Icon.Maximize}"
                      Foreground="#888" />
          </Button>
          <Button Classes="wchrome close"
                  Name="CloseButton"
                  Click="CloseButton_Click">
            <PathIcon Width="11" Height="11"
                      Data="{StaticResource Icon.Close}"
                      Foreground="#888" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Main content ─────────────────────────────────────────────────── -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="32,24,32,24" Spacing="20" MaxWidth="786" MinWidth="786" HorizontalAlignment="Center">

        <!-- Drop zone -->
        <Border Name="DropZone"
                Background="#1A1A1A"
                BorderBrush="#2D2D2D"
                BorderThickness="1"
                CornerRadius="8"
                MinHeight="100"
                Cursor="Hand"
                PointerPressed="DropZone_PointerPressed"
                DragDrop.AllowDrop="True"
                ToolTip.Tip="Drag a file here or press Ctrl+O to browse">
          <Panel>
            <!-- Empty state -->
            <StackPanel IsVisible="{Binding !HasMedia}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Margin="0,24">
              <PathIcon Width="28" Height="28"
                        HorizontalAlignment="Center"
                        Data="{StaticResource Icon.Open}"
                        Foreground="#3D3D3D" />
              <TextBlock Text="Drop a file here, or click to browse"
                         FontSize="14"
                         Foreground="#555"
                         HorizontalAlignment="Center" />
              <TextBlock Text="Audio and video formats supported"
                         FontSize="12"
                         Foreground="#3A3A3A"
                         HorizontalAlignment="Center" />
            </StackPanel>

            <!-- File loaded state -->
            <StackPanel IsVisible="{Binding HasMedia}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="4"
                        Margin="0,20">
              <TextBlock Text="{Binding InputFileName}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="#DEDAD5"
                         HorizontalAlignment="Center" />
              <TextBlock Text="Click to change file"
                         FontSize="11"
                         Foreground="#444"
                         HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Inspecting overlay -->
            <Border IsVisible="{Binding IsInspecting}"
                    Background="#1A1A1A"
                    CornerRadius="8">
              <TextBlock Text="Inspecting file…"
                         FontSize="13"
                         Foreground="#555"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="0,32" />
            </Border>
          </Panel>
        </Border>

        <!-- Media info panel -->
        <Border IsVisible="{Binding HasMedia}"
                Background="#161616"
                BorderBrush="#242424"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16,12">
          <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto,Auto" >
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Format"
                       FontSize="12" Foreground="#555" Margin="0,0,0,7" />
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{Binding MediaSummaryFormat}"
                       FontSize="12" Foreground="#C0BBB8" Margin="0,0,0,7" />

            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Video"
                       FontSize="12" Foreground="#555" Margin="0,0,0,7" />
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding MediaSummaryVideo}"
                       FontSize="12"
                       Foreground="#C0BBB8"
                       Margin="0,0,0,7" />

            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Audio"
                       FontSize="12" Foreground="#555" Margin="0,0,0,7" />
            <TextBlock Grid.Row="2" Grid.Column="1"
                       Text="{Binding MediaSummaryAudio}"
                       FontSize="12" Foreground="#C0BBB8" Margin="0,0,0,7" />

            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="Subtitles"
                       FontSize="12" Foreground="#555" />
            <TextBlock Grid.Row="3" Grid.Column="1"
                       Text="{Binding MediaSummarySubtitles}"
                       FontSize="12" Foreground="#C0BBB8" />
          </Grid>
        </Border>

        <!-- Options panel -->
        <StackPanel IsVisible="{Binding HasMedia}" Spacing="12">

          <!-- Output format -->
          <Grid ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0"
                       Text="Output format"
                       FontSize="13" Foreground="#888"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      IsEnabled="{Binding IsInputEnabled}"
                      ItemsSource="{Binding Formats}"
                      SelectedItem="{Binding SelectedFormat}"
                      HorizontalAlignment="Stretch"
                      Background="#1E1E1E"
                      BorderBrush="#303030"
                      Foreground="#DEDAD5"
                      CornerRadius="5"
                      Padding="10,6">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}" FontSize="13" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <!-- Conversion mode -->
          <Grid ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0"
                       Text="Mode"
                       FontSize="13" Foreground="#888"
                       VerticalAlignment="Center" />
            <Border Grid.Column="1"
                    Background="#1A1A1A"
                    BorderBrush="#2D2D2D"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="3">
              <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0"
                        Classes="seg"
                        Classes.seg-on="{Binding IsFastConvert}"
                        Command="{Binding SetFastConvertOnCommand}"
                        IsEnabled="{Binding IsInputEnabled}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        CornerRadius="4,2,2,4"
                        ToolTip.Tip="Stream copy — no re-encoding; instant but output codec must match input (Spacebar to toggle)">
                  <TextBlock Text="Fast" FontSize="12" />
                </Button>
                <Button Grid.Column="1"
                        Classes="seg"
                        Classes.seg-on="{Binding IsFullConvert}"
                        Command="{Binding SetFullConvertCommand}"
                        IsEnabled="{Binding IsInputEnabled}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        CornerRadius="2,4,4,2"
                        ToolTip.Tip="Re-encode to the selected format's target codec and quality (Spacebar to toggle)">
                  <TextBlock Text="Full re-encode" FontSize="12" />
                </Button>
              </Grid>
            </Border>
          </Grid>

          <!-- Audio track selector (only if input has multiple audio tracks) -->
          <Grid IsVisible="{Binding ShowAudioTrackSelector}"
                ColumnDefinitions="130,*"
                RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Audio"
                       FontSize="13" Foreground="#888"
                       VerticalAlignment="Center" />
            <Button Grid.Row="0" Grid.Column="1"
                    Name="AudioTracksButton"
                    IsEnabled="{Binding IsInputEnabled}"
                    Command="{Binding ToggleAudioTracksDropdownCommand}"
                    Background="#1E1E1E"
                    BorderBrush="#303030"
                    Foreground="#DEDAD5"
                    CornerRadius="5"
                    Padding="10,6"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    FontSize="13">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding AudioTracksDisplayText}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="▼" Margin="8,0,0,0" Opacity="0.6" />
              </Grid>
            </Button>

            <!-- Dropdown popup with audio tracks -->
            <Popup Grid.Row="1" Grid.Column="1"
                   Name="AudioTracksPopup"
                   IsOpen="{Binding ShowAudioTracksDropdown}"
                   PlacementTarget="{Binding #AudioTracksButton}"
                   Placement="Bottom">
              <Border Background="#1A1A1A"
                      BorderBrush="#303030"
                      BorderThickness="1"
                      CornerRadius="5"
                      MinWidth="300"
                      MaxWidth="400">
                <Grid RowDefinitions="*,Auto">
                  <Border Grid.Row="0" Padding="10,6,10,0">
                    <StackPanel Spacing="8">
                      <CheckBox IsChecked="{Binding AudioCheckState}"
                                Command="{Binding ToggleAllAudioCommand}"
                                IsEnabled="{Binding IsInputEnabled}"
                                Margin="0,3"
                                Foreground="#DEDAD5"
                                FontSize="13"
                                FontWeight="SemiBold">
                        All
                      </CheckBox>
                      <ScrollViewer MaxHeight="250"
                                    VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding AudioTracks}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <CheckBox IsChecked="{Binding IsSelected}"
                                        IsEnabled="{Binding $parent[Window].DataContext.IsInputEnabled}"
                                        Margin="12,3,0,3"
                                        Foreground="#DEDAD5">
                                <TextBlock Text="{Binding Label}"
                                           FontSize="13"
                                           TextWrapping="Wrap" />
                              </CheckBox>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </StackPanel>
                  </Border>
                  <Border Grid.Row="1"
                          Background="#0D0D0D"
                          Padding="10,8">
                    <Button HorizontalAlignment="Right"
                            Command="{Binding ToggleAudioTracksDropdownCommand}"
                            Background="Transparent"
                            BorderBrush="#3D3D3D"
                            Foreground="#888"
                            CornerRadius="4"
                            Padding="14,5"
                            FontSize="12"
                            Content="Done" />
                  </Border>
                </Grid>
              </Border>
            </Popup>
          </Grid>

          <!-- Subtitle mode (only if input has subtitles) -->
          <Grid IsVisible="{Binding ShowSubtitleMode}"
                ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0"
                       Text="Subtitles"
                       FontSize="13" Foreground="#888"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      IsEnabled="{Binding IsInputEnabled}"
                      ItemsSource="{Binding SubtitleModes}"
                      SelectedItem="{Binding SelectedSubtitleModeOption}"
                      HorizontalAlignment="Stretch"
                      Background="#1E1E1E"
                      BorderBrush="#303030"
                      Foreground="#DEDAD5"
                      CornerRadius="5"
                      Padding="10,6">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" FontSize="13" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <!-- Subtitle track selector (only if extracting subtitles) -->
          <Grid IsVisible="{Binding ShowSubtitleTrackSelector}"
                ColumnDefinitions="130,*"
                RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Tracks"
                       FontSize="13" Foreground="#888"
                       VerticalAlignment="Center" />
            <Button Grid.Row="0" Grid.Column="1"
                    Name="SubtitleTracksButton"
                    IsEnabled="{Binding IsInputEnabled}"
                    Command="{Binding ToggleSubtitleTracksDropdownCommand}"
                    Background="#1E1E1E"
                    BorderBrush="#303030"
                    Foreground="#DEDAD5"
                    CornerRadius="5"
                    Padding="10,6"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    FontSize="13">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding SubtitleTracksDisplayText}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="▼" Margin="8,0,0,0" Opacity="0.6" />
              </Grid>
            </Button>

            <!-- Dropdown popup with subtitle tracks -->
            <Popup Grid.Row="1" Grid.Column="1"
                   Name="SubtitleTracksPopup"
                   IsOpen="{Binding ShowSubtitleTracksDropdown}"
                   PlacementTarget="{Binding #SubtitleTracksButton}"
                   Placement="Bottom">
              <Border Background="#1A1A1A"
                      BorderBrush="#303030"
                      BorderThickness="1"
                      CornerRadius="5"
                      MinWidth="300"
                      MaxWidth="400">
                <Grid RowDefinitions="*,Auto">
                  <Border Grid.Row="0" Padding="10,6,10,0">
                    <StackPanel Spacing="8">
                      <CheckBox IsChecked="{Binding SubtitleCheckState}"
                                Command="{Binding ToggleAllSubtitlesCommand}"
                                IsEnabled="{Binding IsInputEnabled}"
                                Margin="0,3"
                                Foreground="#DEDAD5"
                                FontSize="13"
                                FontWeight="SemiBold">
                        All
                      </CheckBox>
                      <ScrollViewer MaxHeight="250"
                                    VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SubtitleTracks}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <CheckBox IsChecked="{Binding IsSelected}"
                                        IsEnabled="{Binding $parent[Window].DataContext.IsInputEnabled}"
                                        Margin="12,3,0,3"
                                        Foreground="#DEDAD5">
                                <TextBlock Text="{Binding Label}"
                                           FontSize="13"
                                           TextWrapping="Wrap" />
                              </CheckBox>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </StackPanel>
                  </Border>
                  <Border Grid.Row="1"
                          Background="#0D0D0D"
                          Padding="10,8">
                    <Button HorizontalAlignment="Right"
                            Command="{Binding ToggleSubtitleTracksDropdownCommand}"
                            Background="Transparent"
                            BorderBrush="#3D3D3D"
                            Foreground="#888"
                            CornerRadius="4"
                            Padding="14,5"
                            FontSize="12"
                            Content="Done" />
                  </Border>
                </Grid>
              </Border>
            </Popup>
          </Grid>

          <!-- Output path -->
          <Grid ColumnDefinitions="130,*,Auto">
            <TextBlock Grid.Column="0"
                       Text="Save to"
                       FontSize="13" Foreground="#888"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     IsEnabled="{Binding IsInputEnabled}"
                     Text="{Binding OutputFilePath}"
                     Background="#1E1E1E"
                     BorderBrush="#303030"
                     Foreground="#DEDAD5"
                     CornerRadius="5,0,0,5"
                     Padding="10,6"
                     FontSize="13" />
            <Button Grid.Column="2"
                    IsEnabled="{Binding IsInputEnabled}"
                    Command="{Binding BrowseOutputPathCommand}"
                    Background="#2A2A2A"
                    BorderBrush="#303030"
                    BorderThickness="1,1,1,1"
                    CornerRadius="0,5,5,0"
                    Padding="10,6"
                    Content="Browse" />
          </Grid>

        </StackPanel>

        <!-- Convert button -->
        <Button Classes="accent"
                IsVisible="{Binding !IsConverting}"
                IsEnabled="{Binding HasMedia}"
                Command="{Binding StartConversionCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                FontSize="14"
                Padding="0,10"
                ToolTip.Tip="Convert the current file (Enter)"
                Content="Convert" />

        <!-- Progress bar + status -->
        <StackPanel IsVisible="{Binding IsConverting}" Spacing="10">
          <!-- Enhanced progress bar with glow -->
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Border Grid.Column="0"
                    Background="#252525"
                    CornerRadius="4"
                    Height="12"
                    BoxShadow="0 0 12 rgba(58,110,155,0.4)"
                    VerticalAlignment="Center">
              <ProgressBar Value="{Binding ProgressPercent}"
                           Maximum="100"
                           Height="12"
                           CornerRadius="4"
                           Foreground="#3A6E9B"
                           Background="Transparent"
                           BorderThickness="0" />
            </Border>
            <!-- Live Speed update -->
            <TextBlock Grid.Column="1"
                       Text="{Binding SpeedText}"
                       FontSize="12" Foreground="#5DA4D6"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       FontWeight="SemiBold"
                       Name="SpeedIndicator" />
            <!-- Live ETA update -->
            <TextBlock Grid.Column="2"
                       Text="{Binding EtaText}"
                       FontSize="12" Foreground="#5DA4D6"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       FontWeight="SemiBold"
                       Name="EtaIndicator" />
          </Grid>
          <!-- Status with animated percentage and pulsing indicator -->
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="6">
              <!-- Animated percentage counter -->
              <TextBlock FontSize="13"
                         Foreground="#3A6E9B"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         Name="ProgressText">
                <TextBlock.Text>
                  <MultiBinding StringFormat="Converting… {0:F0}%">
                    <Binding Path="ProgressPercent" />
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <!-- Pulsing activity dot -->
              <Ellipse Width="6" Height="6"
                       Fill="#3A6E9B"
                       VerticalAlignment="Center"
                       Name="ActivityPulse"
                       Opacity="0.7" />
            </StackPanel>
            <Button Grid.Column="1"
                    Command="{Binding CancelConversionCommand}"
                    Background="#2A2A2A"
                    BorderBrush="#3D3D3D"
                    Foreground="#C8C3C2"
                    CornerRadius="4"
                    Padding="14,5"
                    FontSize="12"
                    Content="Cancel" />
          </Grid>
        </StackPanel>

        <!-- Complete state -->
        <Border IsVisible="{Binding IsComplete}"
                Background="#0D171F"
                BorderBrush="#1F303D"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Text="✓  Conversion complete"
                       FontSize="13"
                       Foreground="#5DA4D6"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Command="{Binding OpenOutputFolderCommand}"
                    Background="Transparent"
                    BorderBrush="#1F303D"
                    Foreground="#5DA4D6"
                    CornerRadius="4"
                    Padding="10,4"
                    FontSize="12"
                    Content="Open folder" />
          </Grid>
        </Border>

        <!-- Error state -->
        <Border IsVisible="{Binding HasError}"
                Background="#1F0D0D"
                BorderBrush="#3D1F1F"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10">
          <TextBlock Text="{Binding ErrorMessage}"
                     FontSize="12"
                     Foreground="#C85050"
                     TextWrapping="Wrap" />
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- ── Footer ────────────────────────────────────────────────────────── -->
    <Border Grid.Row="2" Background="#0D0D0D">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="5">
        <TextBlock Text="Powered by"
                   FontSize="11"
                   Foreground="#333"
                   VerticalAlignment="Center" />
        <Viewbox Width="12"
                 Height="12"
                 VerticalAlignment="Center">
          <Canvas Width="256" Height="256">
            <Path Data="{StaticResource Icon.LumynSignal1}" Stroke="#3A9B4B" StrokeThickness="18" StrokeLineCap="Round" />
            <Path Data="{StaticResource Icon.LumynSignal2}" Stroke="#3A9B4B" StrokeThickness="18" StrokeLineCap="Round" />
            <Path Data="{StaticResource Icon.LumynSignal3}" Stroke="#3A9B4B" StrokeThickness="18" StrokeLineCap="Round" />
            <Path Data="{StaticResource Icon.LumynSignal4}" Stroke="#3A9B4B" StrokeThickness="18" StrokeLineCap="Round" />
            <Path Data="{StaticResource Icon.LumynSignal5}" Stroke="#3A9B4B" StrokeThickness="18" StrokeLineCap="Round" />
            <Path Data="{StaticResource Icon.LumynBody}" Stroke="#3A9B4B" StrokeThickness="18" StrokeLineCap="Round" StrokeJoin="Round" />
            <Path Data="{StaticResource Icon.LumynStand1}" Stroke="#3A9B4B" StrokeThickness="12" StrokeLineCap="Round" />
            <Path Data="{StaticResource Icon.LumynStand2}" Stroke="#3A9B4B" StrokeThickness="12" StrokeLineCap="Round" />
            <Path Data="{StaticResource Icon.LumynPlay}" Fill="#D8D4CF" />
          </Canvas>
        </Viewbox>
        <TextBlock Text="Lumyn"
                   FontSize="11"
                   Foreground="#333"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Border>

  </Grid>
</Window>
